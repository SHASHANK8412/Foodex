NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/foodex
JWT_SECRET=replace_with_a_secure_secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=google_client_id_from_google_cloud
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_if_you_create_one
KAFKA_ENABLED=false
KAFKA_CLIENT_ID=foodex-backend
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=foodex-order-processors
ANALYTICS_OUTPUT_DIR=./analytics/output
